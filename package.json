{
  "name": "doxshield",
  "version": "1.0.0",
  "description": "Real-time data sovereignty monitor for European users",
  "main": "out/main/index.js",
  "scripts": {
    "predev": "pkill -f 'Electron.*DoxShield\\|electron-vite\\|python3.*main\\.py' 2>/dev/null; sleep 0.5; exit 0",
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-builder --dir",
    "build:sidecar": "cd sidecar && .venv/bin/pyinstaller sidecar.spec --distpath dist --workpath /tmp/pyinstaller-work --noconfirm",
    "dist": "npm run build:sidecar && electron-vite build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.0.0",
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.1.7",
    "framer-motion": "^11.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1",
    "lottie-react": "^2.4.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.24.0",
    "react-simple-maps": "^3.0.0",
    "recharts": "^2.12.0",
    "tailwind-merge": "^2.3.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^29.4.6",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "app.doxshield.mac",
    "productName": "Doxshield",
    "copyright": "© 2026 Doxshield",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ],
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSAppleEventsUsageDescription": "Doxshield needs access to monitor application activity.",
        "NSNetworkVolumesUsageDescription": "Doxshield monitors network connections for privacy analysis."
      }
    },
    "dmg": {
      "title": "${productName} ${version}",
      "iconSize": 100,
      "contents": [
        { "x": 130, "y": 220, "type": "file" },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ],
      "window": { "width": 540, "height": 380 }
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "sidecar/dist/",
        "to": "sidecar/dist/",
        "filter": ["doxshield-sidecar"]
      },
      {
        "from": "sidecar/",
        "to": "sidecar/",
        "filter": [
          "data/**",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!.venv/**",
          "!dist/**"
        ]
      }
    ]
  }
}
